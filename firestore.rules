rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isPro() {
      return isSignedIn()
        && request.auth.token.role in ['paid', 'admin', 'free_full'];
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    // ── Review Summaries ────────────────────────────────────────────────────────
    // Public read. Only Cloud Function (Admin SDK) can write.
    match /review_summaries/{summaryId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Reviews ────────────────────────────────────────────────────────────────
    // Only Pro members can read reviews. Only authenticated users can create.
    // Users cannot set moderation fields — only Cloud Functions (Admin SDK) can.
    // Admins can moderate (update/delete).
    match /reviews/{reviewId} {
      allow read: if isPro();
      allow create: if isSignedIn() 
                    && request.resource.data.userId == request.auth.uid
                    && !('moderationStatus' in request.resource.data && request.resource.data.moderationStatus != 'pending')
                    && !('moderationReason' in request.resource.data)
                    && !('flaggedSegments' in request.resource.data);
      allow update, delete: if isAdmin();
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    // Users can read their own profile; admins can read all.
    // Users can ONLY update safe preference fields — billing/role fields are
    // written exclusively by Cloud Functions via the Admin SDK (bypasses rules).
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);

      // Full write for admins (Admin SDK bypasses rules anyway, but this covers
      // any future admin panel writes that use the client SDK).
      allow write: if isAdmin();

      // Users can update only their own safe fields.
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['trackedCompanies', 'notificationPreferences', 'updatedAt']);
    }

    // ── Companies ─────────────────────────────────────────────────────────────
    // Public read. Admins can manage data.
    match /companies/{companyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Webhook Debug Logs ──────────────────────────────────────────────────────
    // Written by backend Cloud Functions (uses Admin SDK, bypasses rules).
    // No client-side access.
    match /webhooks_debug/{logId} {
      allow read, write: if false;
    }

    // ── Config (pricing, etc.) ────────────────────────────────────────────────
    // Anyone can read config (pricing page needs it). Only admins can write.
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Newsletters (campaign history) ──────────────────────────────────────────
    // Only administrators can read or write campaign analytics.
    match /newsletters/{newsletterId} {
      allow read, write: if isAdmin();
      
      match /opens/{uid} {
        allow read, write: if isAdmin();
      }
    }

  }
}
