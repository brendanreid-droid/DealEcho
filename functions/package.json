{
  "name": "dealecho-functions",
  "description": "DealEcho Firebase Cloud Functions",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^7.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.3",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript": "~5.8.2",
    "vitest": "^4.1.9"
  },
  "private": true
}
